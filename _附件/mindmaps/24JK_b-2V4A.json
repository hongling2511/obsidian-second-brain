{
  "name": "暗网（Dark Web）深度解析",
  "children": [
    {
      "name": "基本概念",
      "children": [
        {
          "name": "定义：需特殊工具访问的隐藏网络"
        },
        {
          "name": "特性：高度匿名、隐私保护、难以追踪"
        },
        {
          "name": "双重含义",
          "children": [
            {
              "name": "黑暗网络：如Tor、I2P等底层基础设施"
            },
            {
              "name": "黑暗网站：搭建在上述网络中的隐藏服务"
            }
          ]
        }
      ]
    },
    {
      "name": "网络层级划分",
      "children": [
        {
          "name": "表网：搜索引擎可直接抓取的公共网络"
        },
        {
          "name": "深网：需权限或无法搜索的内容（占互联网90%+）"
        },
        {
          "name": "暗网：深网的一部分，需特定工具访问"
        },
        {
          "name": "都市传说：银网、玛利亚纳网"
        }
      ]
    },
    {
      "name": "Tor (洋葱路由) 原理",
      "children": [
        {
          "name": "核心机制：三层中继节点转发"
        },
        {
          "name": "节点类型",
          "children": [
            {
              "name": "入口节点（守卫）：仅知用户IP"
            },
            {
              "name": "中间节点：仅起转发作用"
            },
            {
              "name": "出口节点：与目标网站通信，易受法律审计"
            }
          ]
        },
        {
          "name": "加密方式：多层加密，每层解密一个地址"
        },
        {
          "name": "安全周期：每10分钟自动更换链路"
        }
      ]
    },
    {
      "name": "暗网生态与风险",
      "children": [
        {
          "name": "负面内容：毒品、枪支、暴力、黑客、非法直播"
        },
        {
          "name": "正面用途：对抗审查、保护隐私（如CIA、BBC暗网版）"
        },
        {
          "name": "常见陷阱：诈骗网站占比极高，存在病毒诱导"
        },
        {
          "name": "心理影响：可能造成心理创伤"
        }
      ]
    },
    {
      "name": "各平台进入方法",
      "children": [
        {
          "name": "电脑端 (Win/Mac/Linux)",
          "children": [
            {
              "name": "下载：必须通过官方网站下载Tor浏览器"
            },
            {
              "name": "连接方式：直接连接、使用内置网桥、配置Socks5代理"
            }
          ]
        },
        {
          "name": "移动端",
          "children": [
            {
              "name": "Android：官方Tor浏览器，可配合OBFS网桥"
            },
            {
              "name": "iOS：推荐第三方便开源软件 Onion Browser"
            }
          ]
        },
        {
          "name": "网络环境配置",
          "children": [
            {
              "name": "解决干扰：关闭“流量嗅探”功能"
            },
            {
              "name": "网桥技术：obfs4、snowflake（绕过防火墙）"
            }
          ]
        }
      ]
    },
    {
      "name": "安全建议",
      "children": [
        {
          "name": "严禁违法犯罪活动"
        },
        {
          "name": "提高网络安全意识，防止信息泄露"
        },
        {
          "name": "设置安全等级：禁用JavaScript脚本"
        },
        {
          "name": "保持心理健康：多接触积极阳光事物"
        }
      ]
    }
  ]
}