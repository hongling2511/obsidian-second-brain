{
  "name": "旁路由（旁路网关）配置与原理指南",
  "children": [
    {
      "name": "核心概念",
      "children": [
        {
          "name": "定义：主路由旁连接的科学上网设备"
        },
        {
          "name": "别称：透明网关、网关代理、透明代理"
        },
        {
          "name": "解决问题：分流配置繁琐、主路由稳定性、插件冲突"
        }
      ]
    },
    {
      "name": "网络拓扑结构",
      "children": [
        {
          "name": "传统结构：光猫 -> 主路由 -> 终端设备"
        },
        {
          "name": "旁路由结构：主路由与旁路由同局域网，终端网关指向旁路由"
        }
      ]
    },
    {
      "name": "配置步骤",
      "children": [
        {
          "name": "旁路由基础设置",
          "children": [
            {
              "name": "修改LAN口IP：与主路由同网段且不冲突"
            },
            {
              "name": "设置网关：指向主路由IP"
            },
            {
              "name": "设置DNS：指向主路由或公共DNS"
            },
            {
              "name": "关闭/开启DHCP：根据需求决定由谁分配IP"
            }
          ]
        },
        {
          "name": "家庭分流进阶设置",
          "children": [
            {
              "name": "静态地址绑定：MAC与IP映射"
            },
            {
              "name": "DHCP选项：代码3（网关）、代码6（DNS）"
            },
            {
              "name": "按设备分流：不同标签分配不同网关"
            }
          ]
        }
      ]
    },
    {
      "name": "常见问题与原理分析",
      "children": [
        {
          "name": "非对称路由",
          "children": [
            {
              "name": "现象：国内网站无法访问或丢包"
            },
            {
              "name": "原因：往返路径不一致导致无效数据包判定"
            },
            {
              "name": "解决方法：防火墙取消“丢弃无效数据包”"
            }
          ]
        },
        {
          "name": "WiFi访问异常",
          "children": [
            {
              "name": "原因：iptables记录五元组，未进行NAT处理"
            },
            {
              "name": "解决方法：开启“IP动态伪装”（MASQUERADE/NAT）"
            }
          ]
        },
        {
          "name": "IPv6问题",
          "children": [
            {
              "name": "风险：绕过旁路由导致翻墙失效"
            },
            {
              "name": "建议：普通用户优先关闭IPv6"
            }
          ]
        }
      ]
    },
    {
      "name": "评价与争议",
      "children": [
        {
          "name": "优点：不改变原有网路物理结构，配置灵活"
        },
        {
          "name": "缺点：非标准拓扑，配置复杂时易出错，二次NAT损耗性能"
        },
        {
          "name": "适用人群：普通家庭网络环境"
        }
      ]
    }
  ]
}