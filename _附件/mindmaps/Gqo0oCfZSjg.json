{
  "name": "Go语言追踪工具与并发优化",
  "children": [
    {
      "name": "初始单线程版本",
      "children": [
        {
          "name": "算法：线性遍历4000个文档"
        },
        {
          "name": "性能：耗时约1秒"
        },
        {
          "name": "瓶颈：系统调用 (System Calls)"
        },
        {
          "name": "分析工具：CPU Profile (显示正在发生的事)"
        }
      ]
    },
    {
      "name": "Go Trace 工具",
      "children": [
        {
          "name": "功能：显示程序中“未发生”的事"
        },
        {
          "name": "视角：Proc级别查看16个核心利用率"
        },
        {
          "name": "观察结果：仅使用单个核心，其余闲置"
        },
        {
          "name": "指标：协程状态、堆内存图、GC频率"
        }
      ]
    },
    {
      "name": "并发改进策略",
      "children": [
        {
          "name": "方案一：扇出 (Fan Out)",
          "children": [
            {
              "name": "做法：为每个文档开启一个Go协程"
            },
            {
              "name": "同步：使用 WaitGroup 等待完成"
            },
            {
              "name": "竞态处理：使用 Atomic 原子操作解决变量冲突"
            },
            {
              "name": "内存优化：使用局部变量减少缓存行抖动 (Thrashing)"
            },
            {
              "name": "结果：性能大幅提升 (约264ms)，利用全核"
            }
          ]
        },
        {
          "name": "方案二：协程池 (Pooling)",
          "children": [
            {
              "name": "做法：按核心数创建固定数量协程 (16个)"
            },
            {
              "name": "机制：通过有缓冲 Channel 分发任务"
            },
            {
              "name": "异常发现：性能反而变慢 (约388ms)"
            },
            {
              "name": "Trace分析：GC步调过紧，内存限制在13MB"
            }
          ]
        }
      ]
    },
    {
      "name": "运行时调优 (Runtime Tuning)",
      "children": [
        {
          "name": "GOGC 调节",
          "children": [
            {
              "name": "默认值：100 (4MB触发GC)"
            },
            {
              "name": "调整：设为 1000 (提高首个GC触发门槛)"
            },
            {
              "name": "效果：GC频率大幅降低，耗时缩减至136ms"
            }
          ]
        },
        {
          "name": "GOMEMLIMIT 内存限制",
          "children": [
            {
              "name": "功能：设置软内存上限 (如60MB)"
            },
            {
              "name": "优势：让运行时在指定空间内高效工作"
            },
            {
              "name": "结果：性能与关闭GC几乎一致，更可控"
            }
          ]
        }
      ]
    },
    {
      "name": "核心结论",
      "children": [
        {
          "name": "并发定义：无序执行 (Out of Order)"
        },
        {
          "name": "首选建议：直接抛出协程让调度器处理"
        },
        {
          "name": "性能关键：有时候仅需给程序更多内存"
        },
        {
          "name": "工具价值：Trace 能揭示调度与内存的深层互动"
        }
      ]
    }
  ]
}