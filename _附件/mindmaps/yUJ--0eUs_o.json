              "name": "Shadowrocket (小火箭)"
            },
            {
              "name": "v2rayNG / NB4A"
            },
            {
              "name": "Mihomo (原Clash.Meta)"
            }
          ]
        }
      ]
    },
    {
      "name": "AnyTLS搭建方式",
      "children": [
        {
          "name": "方式一：AnyTLS-Go (Demo版)",
          "children": [
            {
              "name": "特点：简单快速，默认自签名证书"
            },
            {
              "name": "服务端：anytls-server 命令行运行"
            },
            {
              "name": "客户端：anytls-client 转 Socks5"
            }
          ]
        },
        {
          "name": "方式二：Mihomo (内核版)",
          "children": [
            {
              "name": "特点：支持复杂规则与个性化Padding"
            },
            {
              "name": "配置：需设置监听端口、密码、证书路径"
            },
            {
              "name": "自定义：可指定前N个数据包的填充范围"
            }
          ]
        }
      ]
    },
    {
      "name": "搭建建议与优化",
      "children": [
        {
          "name": "VPS选择：建议自行搭建以规避机场攻击"
        },
        {
          "name": "证书：推荐使用正规CA证书并开启SNI"
        },
        {
          "name": "安全：自签名证书需勾选“允许不安全”"
        },
        {
          "name": "后台运行：使用 nohup 或相关命令持久化"
        }
      ]
