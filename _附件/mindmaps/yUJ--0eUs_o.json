              "name": "表现：通常第二天IP被封"
            }
          ]
        },
        {
          "name": "VMess + WS",
          "children": [
            {
              "name": "风险：频繁封锁端口"
            },
            {
              "name": "现状：2024年起不再推荐"
            }
          ]
        },
        {
          "name": "VLESS + TLS + Vision",
          "children": [
            {
              "name": "表现：端口或域名可能被阻断"
