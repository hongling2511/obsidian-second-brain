        {
          "name": "配置风险: 默认开启缓存 (Cache) 增加被攻击概率"
        }
      ]
    },
    {
      "name": "攻击实战演示",
      "children": [
        {
          "name": "版本识别: 通过 /version 接口查看"
        },
        {
          "name": "获取配置: 访问 /render 或 /sub 路径穿越获取 Token"
        },
        {
          "name": "恶意指令注入: 将脚本写入缓存目录"
        },
        {
          "name": "触发执行: 通过特定接口执行缓存脚本获取 Shell"
        },
        {
          "name": "结果: 拿到 Root 权限，窃取所有用户节点"
        }
      ]
    },
    {
      "name": "漏洞成因",
      "children": [
        {
          "name": "路径穿越过滤不严"
        },
        {
          "name": "API Mode 设为 False (未强制验证 Token)"
        },
        {
          "name": "使用默认弱口令 Token (如: password)"
        },
        {
          "name": "旧版本接口泄露敏感配置文件"
        }
      ]
    },
    {
      "name": "防御与安全建议",
      "children": [
        {
          "name": "针对服务提供者",
          "children": [
            {
              "name": "更新代码: 使用 2022.08 后的最新版本"
            },
            {
              "name": "配置强制: API Mode 必须设为 True"
            },
            {
              "name": "增强凭据: 设置复杂的 Token"
            },
            {
              "name": "关闭缓存: 彻底杜绝 RCE 风险"
            },
