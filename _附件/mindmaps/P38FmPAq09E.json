{
  "name": "家庭网络通信流程",
  "children": [
    {
      "name": "网络硬件组成",
      "children": [
        {
          "name": "光猫 (Modem)"
        },
        {
          "name": "路由器 (Router)",
          "children": [
            {
              "name": "WAN口: 连接外网/光猫"
            },
            {
              "name": "LAN口: 连接内网设备"
            },
            {
              "name": "管理IP/网关: 192.168.1.1"
            }
          ]
        },
        {
          "name": "交换机 (Switch)",
          "children": [
            {
              "name": "MAC地址映射表"
            },
            {
              "name": "数据帧转发"
            }
          ]
        }
      ]
    },
    {
      "name": "核心网络协议与服务",
      "children": [
        {
          "name": "DHCP (动态主机配置协议)",
          "children": [
            {
              "name": "功能: 自动分配IP、子网掩码、网关、DNS"
            },
            {
              "name": "端口: 客户端68, 服务端67"
            },
            {
              "name": "流程: 广播请求 -> 服务端响应 -> 租约确认"
            },
            {
              "name": "异常: 169.254.x.x (获取失败)"
            }
          ]
        },
        {
          "name": "DNS (域名系统)",
          "children": [
            {
              "name": "功能: 域名转换为IP地址"
            },
            {
              "name": "端口: UDP 53"
            },
            {
              "name": "机制: 递归查询与缓存 (TTL)"
            }
          ]
        },
        {
          "name": "ARP (地址解析协议)",
          "children": [
            {
              "name": "功能: 通过IP地址获取物理MAC地址"
            },
            {
              "name": "方式: 局域网广播请求"
            },
            {
              "name": "ARP缓存: 减少广播频率"
            }
          ]
        },
        {
          "name": "NAT (网络地址转换)",
          "children": [
            {
              "name": "功能: 私有IP与公网IP转换"
            },
            {
              "name": "核心: NAT映射表"
            },
            {
              "name": "作用: 允许多台内网设备共享公网IP"
            }
          ]
        }
      ]
    },
    {
      "name": "访问网页过程演练",
      "children": [
        {
          "name": "第一阶段: 域名解析",
          "children": [
            {
              "name": "浏览器发起DNS请求"
            },
            {
              "name": "通过ARP获取网关MAC"
            },
            {
              "name": "通过网关查询上游DNS"
            }
          ]
        },
        {
          "name": "第二阶段: 判断网段",
          "children": [
            {
              "name": "利用子网掩码计算网络号"
            },
            {
              "name": "同网段: 直接二层传输"
            },
            {
              "name": "不同网段: 发送给默认网关"
            }
          ]
        },
        {
          "name": "第三阶段: 数据传输与NAT",
          "children": [
            {
              "name": "封装HTTP请求 (TCP 80/443)"
            },
            {
              "name": "路由器执行NAT转换"
            },
            {
              "name": "公网路由转发至目标服务器"
            }
          ]
        },
        {
          "name": "第四阶段: 数据回包",
          "children": [
            {
              "name": "服务器响应回传路由器"
            },
            {
              "name": "路由器查NAT表还原私网IP"
            },
            {
              "name": "浏览器渲染网页内容"
            }
          ]
        }
      ]
    }
  ]
}