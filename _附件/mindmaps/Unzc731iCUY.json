{
  "name": "如何演讲 (How to Speak)",
  "children": [
    {
      "name": "成功公式",
      "children": [
        {
          "name": "知识 (K)"
        },
        {
          "name": "练习 (P)"
        },
        {
          "name": "天赋 (T) - 占比最小"
        }
      ]
    },
    {
      "name": "开场技巧",
      "children": [
        {
          "name": "禁忌：不建议用笑话开场"
        },
        {
          "name": "赋能承诺：告诉听众将学到什么"
        }
      ]
    },
    {
      "name": "演讲启发式范例",
      "children": [
        {
          "name": "循环：重要观点说三次"
        },
        {
          "name": "围栅栏：区分自己的想法与他人"
        },
        {
          "name": "口头标点：提供路标和进度"
        },
        {
          "name": "问问题：等待7秒钟"
        }
      ]
    },
    {
      "name": "环境选择",
      "children": [
        {
          "name": "时间：上午11点最佳"
        },
        {
          "name": "地点：光线充足、事先侦察"
        },
        {
          "name": "人数：坐满一半以上"
        }
      ]
    },
    {
      "name": "演讲工具",
      "children": [
        {
          "name": "黑板",
          "children": [
            {
              "name": "绘图功能"
            },
            {
              "name": "书写速度匹配吸收"
            },
            {
              "name": "让手有事可做"
            }
          ]
        },
        {
          "name": "道具",
          "children": [
            {
              "name": "增加戏剧张力"
            },
            {
              "name": "共情镜像启动神经元"
            },
            {
              "name": "让人印象深刻"
            }
          ]
        },
        {
          "name": "幻灯片",
          "children": [
            {
              "name": "作用：展示而非教学"
            },
            {
              "name": "精简文字：防止阅读分心"
            },
            {
              "name": "去除杂乱：删掉标志和标点"
            },
            {
              "name": "大字号：40-50号字"
            },
            {
              "name": "替代激光笔：使用小箭头"
            }
          ]
        }
      ]
    },
    {
      "name": "特殊场合",
      "children": [
        {
          "name": "求职演说",
          "children": [
            {
              "name": "5分钟内展示愿景"
            },
            {
              "name": "证明已完成的成就"
            },
            {
              "name": "列举具体贡献"
            }
          ]
        },
        {
          "name": "获得名声 (Winston之星)",
          "children": [
            {
              "name": "Symbol 符号"
            },
            {
              "name": "Slogan 标语"
            },
            {
              "name": "Surprise 惊喜"
            },
            {
              "name": "Salient 突出的想法"
            },
            {
              "name": "Story 故事"
            }
          ]
        }
      ]
    },
    {
      "name": "如何结尾",
      "children": [
        {
          "name": "最后一张片子：列出贡献 (Contribution)"
        },
        {
          "name": "禁忌：不建议说“谢谢”"
        },
        {
          "name": "方式：讲笑话、祝福、惯例动作或向观众致敬"
        }
      ]
    }
  ]
