{
  "name": "Winston教授：如何演讲",
  "children": [
    {
      "name": "核心理念",
      "children": [
        {
          "name": "成功要素：说话 > 写作 > 思想"
        },
        {
          "name": "成功公式：K(知识) + P(练习) + T(天赋/小)"
        },
        {
          "name": "核心规则：禁止使用电子产品"
        },
        {
          "name": "人类限制：只有一个语言处理器"
        }
      ]
    },
    {
      "name": "开场技巧",
      "children": [
        {
          "name": "不要以笑话开场"
        },
        {
          "name": "赋能承诺：一小时后学到什么"
        }
      ]
    },
    {
      "name": "讲解范例",
      "children": [
        {
          "name": "循环：重要观点说三次"
        },
        {
          "name": "围栅栏：区分自己的想法与他人想法"
        },
        {
          "name": "口头标点：提供路标与数字"
        },
        {
          "name": "提问：等待7秒钟"
        }
      ]
    },
    {
      "name": "时间与地点",
      "children": [
        {
          "name": "最佳时间：上午11点"
        },
        {
          "name": "地点要求：光线充足"
        },
        {
          "name": "事先勘察：模拟空旷环境"
        },
        {
          "name": "人数规模：坐满一半以上"
        }
      ]
    },
    {
      "name": "演讲工具",
      "children": [
        {
          "name": "黑板与道具",
          "children": [
            {
              "name": "绘图功能"
            },
            {
              "name": "书写速度匹配吸收速度"
            },
            {
              "name": "保持手部活动"
            },
            {
              "name": "共情镜像效应"
            }
          ]
        },
        {
          "name": "投影片使用",
          "children": [
            {
              "name": "作用：展示想法而非教学"
            },
            {
              "name": "文字精简：去除背景、标志、标题"
            },
            {
              "name": "字号建议：40或50号字"
            },
            {
              "name": "避免雷射笔：改用小箭头"
            },
            {
              "name": "留白与图像"
            }
          ]
        }
      ]
    },
    {
      "name": "特殊场合",
      "children": [
        {
          "name": "激励学生：展现热情"
        },
        {
          "name": "教人思考：讲故事的方法"
        },
        {
          "name": "求职演说：5分钟内展示愿景与成就"
        },
        {
          "name": "获得名声：温斯顿之星(符号、标语、惊喜、突出想法、过程)"
        }
      ]
    },
    {
      "name": "结尾技巧",
      "children": [
        {
          "name": "最后一张投影片：列出贡献(而非谢谢)"
        },
        {
          "name": "不要说谢谢：软弱的表现"
        },
        {
          "name": "结尾方式：笑话、政治式祝福、向观众致敬"
        }
      ]
    }
  ]
}